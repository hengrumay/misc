{
  "datasets": [
    {
      "name": "kpi_summary",
      "displayName": "Kpi Summary",
      "queryLines": [
        "SELECT COUNT(*) AS total_calls_evaluated,\n",
        "                   ROUND(AVG(overall_qa_score), 2) AS avg_qa_score,\n",
        "                   ROUND(COUNT(CASE WHEN requires_human_review THEN 1 END) * 100.0 / COUNT(*), 1) AS pct_flagged,\n",
        "                   ROUND(AVG(greeting_adherence), 3) AS avg_script_adherence\n",
        "            FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard"
      ]
    },
    {
      "name": "agent_leaderboard",
      "displayName": "Agent Leaderboard",
      "queryLines": [
        "SELECT agent_name, COUNT(*) AS calls_evaluated,\n",
        "                   ROUND(AVG(overall_qa_score), 2) AS avg_score,\n",
        "                   ROUND(AVG(empathy_score), 2) AS avg_empathy,\n",
        "                   COUNT(CASE WHEN requires_human_review THEN 1 END) AS flagged_calls\n",
        "            FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard\n",
        "            GROUP BY agent_name ORDER BY avg_score DESC"
      ]
    },
    {
      "name": "outlier_calls",
      "displayName": "Outlier Calls",
      "queryLines": [
        "SELECT interaction_id, agent_name, queue, overall_qa_score, sentiment, coaching_notes\n",
        "            FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard\n",
        "            WHERE requires_human_review = true\n",
        "            ORDER BY overall_qa_score ASC"
      ]
    },
    {
      "name": "queue_performance",
      "displayName": "Queue Performance",
      "queryLines": [
        "SELECT queue, COUNT(*) AS total_calls, ROUND(AVG(overall_qa_score), 2) AS avg_score,\n",
        "                   COUNT(CASE WHEN overall_qa_score < 3 THEN 1 END) AS poor_calls,\n",
        "                   COUNT(CASE WHEN requires_human_review THEN 1 END) AS flagged\n",
        "            FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard\n",
        "            GROUP BY queue ORDER BY avg_score DESC"
      ]
    },
    {
      "name": "coaching_opportunities",
      "displayName": "Coaching Opportunities",
      "queryLines": [
        "WITH agent_criteria AS (\n",
        "              SELECT agent_name, 'Greeting' AS criterion, AVG(greeting_score) AS avg_score FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard GROUP BY agent_name\n",
        "              UNION ALL SELECT agent_name, 'Identity Verification', AVG(identity_verification_score) FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard GROUP BY agent_name\n",
        "              UNION ALL SELECT agent_name, 'Empathy', AVG(empathy_score) FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard GROUP BY agent_name\n",
        "              UNION ALL SELECT agent_name, 'Compliance', AVG(compliance_score) FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard GROUP BY agent_name\n",
        "              UNION ALL SELECT agent_name, 'Resolution', AVG(resolution_score) FROM mmt_aws_usw2_catalog.contact_calls.gold_scorecard GROUP BY agent_name\n",
        "            )\n",
        "            SELECT agent_name, criterion, ROUND(avg_score, 2) AS avg_criterion_score,\n",
        "                   CASE WHEN avg_score < 2.5 THEN 'URGENT' WHEN avg_score < 3.5 THEN 'COACH' ELSE 'GOOD' END AS action_needed\n",
        "            FROM agent_criteria WHERE avg_score < 3.5 ORDER BY avg_score ASC"
      ]
    }
  ],
